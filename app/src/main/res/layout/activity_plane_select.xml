<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D2B"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择飞机"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- 飞机1 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp"
        android:background="#22224488" android:padding="12dp">
        <Button android:id="@+id/btn_plane1"
            android:layout_width="100dp" android:layout_height="wrap_content"
            android:backgroundTint="#0088FF" android:textColor="#FFFFFF"
            android:textSize="14sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tv_plane1_desc"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CCCCFF"
            android:textSize="13sp" android:fontFamily="monospace"
            android:layout_marginStart="12dp" android:gravity="center_vertical"/>
    </LinearLayout>

    <!-- 飞机2 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp"
        android:background="#22224488" android:padding="12dp">
        <Button android:id="@+id/btn_plane2"
            android:layout_width="100dp" android:layout_height="wrap_content"
            android:backgroundTint="#FF8800" android:textColor="#FFFFFF"
            android:textSize="14sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tv_plane2_desc"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CCCCFF"
            android:textSize="13sp" android:fontFamily="monospace"
            android:layout_marginStart="12dp" android:gravity="center_vertical"/>
    </LinearLayout>

    <!-- 飞机3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="32dp"
        android:background="#22224488" android:padding="12dp">
        <Button android:id="@+id/btn_plane3"
            android:layout_width="100dp" android:layout_height="wrap_content"
            android:backgroundTint="#AA00FF" android:textColor="#FFFFFF"
            android:textSize="14sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tv_plane3_desc"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CCCCFF"
            android:textSize="13sp" android:fontFamily="monospace"
            android:layout_marginStart="12dp" android:gravity="center_vertical"/>
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn_back"
            android:layout_width="120dp" android:layout_height="48dp"
            android:text="返回"
            android:backgroundTint="#333355"
            android:textColor="#CCCCCC"
            android:fontFamily="monospace"
            android:layout_marginEnd="16dp"/>
        <Button android:id="@+id/btn_confirm"
            android:layout_width="160dp" android:layout_height="48dp"
            android:text="出发！"
            android:backgroundTint="#0088CC"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

</LinearLayout>
