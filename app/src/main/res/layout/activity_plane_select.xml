<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D2B">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#12122A"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✈ 选择飞机"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#0D0D2B">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 飞机1：猎鹰号 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                android:background="#1A0088FF"
                android:padding="14dp"
                android:gravity="center_vertical">
                <!-- 飞机图标 -->
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_plane_falcon"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="14dp"/>
                <!-- 信息区 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_plane1"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#0088FF"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_plane1_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#B0C4FF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 飞机2：风暴号 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                android:background="#1AFF8800"
                android:padding="14dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_plane_storm"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="14dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_plane2"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#FF8800"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_plane2_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFD0A0"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 飞机3：猎鹰II号 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:background="#1AAA00FF"
                android:padding="14dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_plane_hunterii"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="14dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_plane3"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#AA00FF"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_plane3_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#D0AAFF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#12122A"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="4dp">
        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="← 返回"
            android:backgroundTint="#2A2A55"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:layout_marginEnd="12dp"/>
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="2"
            android:text="🚀 出发！"
            android:backgroundTint="#0055AA"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>
    </LinearLayout>

</LinearLayout>
