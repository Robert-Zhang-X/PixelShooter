<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D2B"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择关卡"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn_level1" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:backgroundTint="#224499" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tv_best1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn_level2" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:backgroundTint="#993311" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tv_best2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn_level3" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:backgroundTint="#115577" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tv_best3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn_level4" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:backgroundTint="#334433" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tv_best4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="24dp">
        <Button android:id="@+id/btn_level5" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:backgroundTint="#441155" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tv_best5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="120dp"
        android:layout_height="44dp"
        android:text="返回"
        android:layout_gravity="center"
        android:backgroundTint="#333355"
        android:textColor="#CCCCCC"
        android:fontFamily="monospace"/>

</LinearLayout>
