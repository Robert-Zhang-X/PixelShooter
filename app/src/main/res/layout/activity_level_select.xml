<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D0D2B">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="vertical" android:gravity="center"
        android:background="#12122A" android:elevation="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#x26A1; 选择关卡" android:textColor="#FFD700"
            android:textSize="20sp" android:textStyle="bold" android:fontFamily="monospace"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true" android:background="#0D0D2B">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- 关卡1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1A224488" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="56dp" android:layout_height="56dp"
                        android:src="@drawable/ic_level_sky" android:scaleType="fitCenter" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <Button android:id="@+id/btn_level1" android:layout_width="match_parent"
                            android:layout_height="40dp" android:backgroundTint="#224499"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#x2B50; 难度：初级" android:textColor="#FFD700"
                            android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&#x2601; 万里晴空，初出茅庐的试炼之地。敌机编队飞行，Boss：铁翼暴君" android:textColor="#AABBDD"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp" android:lineSpacingMultiplier="1.3"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="可选飞机：" android:textColor="#88AABB" android:textSize="10sp" android:fontFamily="monospace"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_falcon" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_storm" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_hunterii" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <TextView android:id="@+id/tv_best1" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end"
                        android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1A993311" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="56dp" android:layout_height="56dp"
                        android:src="@drawable/ic_level_volcano" android:scaleType="fitCenter" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <Button android:id="@+id/btn_level2" android:layout_width="match_parent"
                            android:layout_height="40dp" android:backgroundTint="#993311"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#x2B50;&#x2B50; 难度：中级" android:textColor="#FF8844"
                            android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&#x1F30B; 熔岩横流，高温烈焰的地狱峡谷。自杀式冲锋机频现，Boss：烈焰魔王" android:textColor="#FFBB88"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp" android:lineSpacingMultiplier="1.3"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="可选飞机：" android:textColor="#88AABB" android:textSize="10sp" android:fontFamily="monospace"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_falcon" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_storm" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_hunterii" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <TextView android:id="@+id/tv_best2" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end"
                        android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1A115577" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="56dp" android:layout_height="56dp"
                        android:src="@drawable/ic_level_ocean" android:scaleType="fitCenter" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <Button android:id="@+id/btn_level3" android:layout_width="match_parent"
                            android:layout_height="40dp" android:backgroundTint="#115577"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#x2B50;&#x2B50;&#x2B50; 难度：困难" android:textColor="#44CCFF"
                            android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&#x1F30A; 海天之间，鱼雷轰炸机密集出击。水雷陷阱与编队包围，Boss：深海领主" android:textColor="#88DDFF"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp" android:lineSpacingMultiplier="1.3"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="可选飞机：" android:textColor="#88AABB" android:textSize="10sp" android:fontFamily="monospace"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_falcon" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_storm" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_hunterii" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <TextView android:id="@+id/tv_best3" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end"
                        android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1A334433" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="56dp" android:layout_height="56dp"
                        android:src="@drawable/ic_level_thunder" android:scaleType="fitCenter" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <Button android:id="@+id/btn_level4" android:layout_width="match_parent"
                            android:layout_height="40dp" android:backgroundTint="#334433"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#x2B50;&#x2B50;&#x2B50;&#x2B50; 难度：极难" android:textColor="#AAFFAA"
                            android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&#x26A1; 雷霆交加，干扰机与护盾战机协同作战。地形与雷电夹击，Boss：雷霆领主" android:textColor="#BBFFBB"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp" android:lineSpacingMultiplier="1.3"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="可选飞机：" android:textColor="#88AABB" android:textSize="10sp" android:fontFamily="monospace"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_falcon" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_storm" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_hunterii" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <TextView android:id="@+id/tv_best4" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end"
                        android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡5 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1A441155" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="56dp" android:layout_height="56dp"
                        android:src="@drawable/ic_level_space" android:scaleType="fitCenter" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <Button android:id="@+id/btn_level5" android:layout_width="match_parent"
                            android:layout_height="40dp" android:backgroundTint="#441155"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#x2620; 难度：噩梦" android:textColor="#FF44FF"
                            android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="&#x1FA90; 星际深处，隐形战机与宇宙分裂者席卷而来。Boss：宇宙毁灭者（可分裂）" android:textColor="#DDAAFF"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp" android:lineSpacingMultiplier="1.3"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="可选飞机：" android:textColor="#88AABB" android:textSize="10sp" android:fontFamily="monospace"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_falcon" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_storm" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_plane_hunterii" android:scaleType="fitCenter" android:layout_marginStart="4dp"/>
                    <TextView android:id="@+id/tv_best5" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end"
                        android:textColor="#AAFFAA" android:textSize="11sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#12122A" android:gravity="center" android:elevation="4dp">
        <Button android:id="@+id/btn_back" android:layout_width="120dp" android:layout_height="44dp"
            android:text="&#x2190; 返回" android:backgroundTint="#2A2A55"
            android:textColor="#AAAACC" android:fontFamily="monospace" android:textSize="13sp"/>
    </LinearLayout>

</LinearLayout>
