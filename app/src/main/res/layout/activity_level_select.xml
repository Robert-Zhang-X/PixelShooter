<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D2B">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#12122A"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 选择关卡"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <!-- 关卡列表（ScrollView 填满剩余空间 → 解决底部黑块） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#0D0D2B">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 关卡1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:background="#1A224488"
                android:padding="10dp"
                android:gravity="center_vertical">
                <!-- 关卡图标 -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_level_sky"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"/>
                <!-- 关卡信息 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_level1"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="#224499"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_best1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFAA"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:background="#1A993311"
                android:padding="10dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_level_volcano"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_level2"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="#993311"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_best2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFAA"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:background="#1A115577"
                android:padding="10dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_level_ocean"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_level3"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="#115577"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_best3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFAA"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:background="#1A334433"
                android:padding="10dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_level_thunder"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_level4"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="#334433"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_best4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFAA"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 关卡5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:background="#1A441155"
                android:padding="10dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_level_space"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btn_level5"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="#441155"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tv_best5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFAA"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 底部返回按钮（贴底，无黑块） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#12122A"
        android:gravity="center"
        android:elevation="4dp">
        <Button
            android:id="@+id/btn_back"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="← 返回"
            android:backgroundTint="#2A2A55"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:textSize="13sp"/>
    </LinearLayout>

</LinearLayout>
